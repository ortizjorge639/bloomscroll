# ─── X (Twitter) OAuth 2.0 ───────────────────────────────────────────────────
# Required for "Connect X Account" feature in Settings.
# Create an app at https://developer.x.com/en/portal/dashboard
#
# App requirements:
#   - OAuth 2.0 enabled (User Authentication Settings)
#   - Type of App: Web App (confidential client)
#   - Callback URL: https://YOUR_DOMAIN/api/auth/x/callback
#   - Required scopes: bookmark.read, tweet.read, users.read, offline.access

X_CLIENT_ID=your_x_client_id_here
X_CLIENT_SECRET=your_x_client_secret_here

# ─── App URL ─────────────────────────────────────────────────────────────────
# The public URL of your deployed app (used for OAuth callback redirect)
# In development this defaults to http://localhost:3000
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# ─── Optional: Vercel Analytics ──────────────────────────────────────────────
# Automatically set by Vercel when using @vercel/analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
